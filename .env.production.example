# Example environment file (production).
# Copy to `.env` on the server and set real values.
#
# IMPORTANT:
# - Set a strong SECRET_KEY.
# - Use HTTPS in production.

APP_ENV=production
FLASK_DEBUG=False

SECRET_KEY=change-me-strong-secret

# Prefer PostgreSQL in production
# Example: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///school_grades.db

# Cookies / session (HTTPS required)
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=7200

# Security headers / HTTPS redirects
FORCE_HTTPS=True

# Reverse proxy (recommended when behind Nginx/Traefik/etc)
USE_PROXYFIX=True
PROXYFIX_X_FOR=1
PROXYFIX_X_PROTO=1
PROXYFIX_X_HOST=1
PROXYFIX_X_PORT=1
PROXYFIX_X_PREFIX=1

# Rate limiting storage (use Redis for multi-worker)
# Example: redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://

# Never bootstrap demo admin/data in production
BOOTSTRAP_DATA=False

