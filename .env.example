# Example environment file (development).
# Copy to `.env` and adjust values.
#
# IMPORTANT:
# - Never commit real `.env` with secrets.
# - Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"

APP_ENV=development
FLASK_DEBUG=True

# Flask secret (required for sessions/CSRF)
SECRET_KEY=change-me

# Database (PostgreSQL)
# Создайте БД: createdb school_grades
DATABASE_URL=postgresql://user:password@localhost:5432/school_grades

# Cookies / session
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=7200

# Макс. размер фото профиля студента (байты). ≤ client_max_body_size в nginx; по умолчанию 5242880 (5 МБ)
MAX_PROFILE_PHOTO_BYTES=5242880

# Rate limiting storage (memory OK for dev)
RATELIMIT_STORAGE_URI=memory://

# DEV-only: optional bootstrap initial data/admin
BOOTSTRAP_DATA=False
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@school.com
BOOTSTRAP_ADMIN_PASSWORD=

